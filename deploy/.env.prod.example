# Phoenix phoenix 生产环境配置模板。
# 复制到服务器 /opt/phoenix/.env 后填写,切勿提交真实值到仓库。

# --- 镜像来源(与 .github/workflows/deploy.yml 一致)---
REGISTRY=registry.cn-hangzhou.aliyuncs.com
REGISTRY_NAMESPACE=yuanyuexiang
# TAG 通常由部署命令注入(TAG=sha-xxxxxxx docker compose ...),不在此固定

# --- 机密(必填)---
POSTGRES_PASSWORD=phoenix
MINIO_ROOT_PASSWORD=phoenix
PHX_ADMIN_PASSWORD=phoenix    # 管理后台访问密码,同时是 mcp→workflow 的内部凭证

# --- 可选覆盖 ---
POSTGRES_USER=phoenix
POSTGRES_DB=phoenix
MINIO_ROOT_USER=phoenix

# --- 大模型(留空用 Mock 提取器;说明书 §13 模型来源可配置)---
PHX_LLM_ENDPOINT=
PHX_LLM_API_KEY=
PHX_LLM_MODEL=deepseek-chat

# --- 视觉大模型(图片转写;留空则上传图片会在提取阶段明确报错)---
PHX_VISION_ENDPOINT=
PHX_VISION_API_KEY=
PHX_VISION_MODEL=qwen-vl-plus

# --- MCP 端点 OAuth 鉴权(docs/MCP-OAuth鉴权方案.md)---
# 首次启用前的一次性准备:给 Keycloak 建库
#   docker exec phoenix-postgres psql -U phoenix -c 'CREATE DATABASE keycloak'
# 灰度步骤(方案 §7):先 optional(有 token 记身份、无 token 放行)观察,再切 required
PHX_OAUTH_MODE=off
PHX_OAUTH_ISSUER=https://phoenix.matrix-net.tech/auth/realms/phoenix
PHX_OAUTH_DISCOVERY_URL=http://keycloak:8080/auth/realms/phoenix
PHX_OAUTH_AUDIENCE=phoenix-mcp
PHX_OAUTH_RESOURCE=https://phoenix.matrix-net.tech/mcp

# --- Keycloak(授权服务器,经 /auth 子路径对外)---
KC_BOOTSTRAP_ADMIN_USERNAME=admin
KC_BOOTSTRAP_ADMIN_PASSWORD=
