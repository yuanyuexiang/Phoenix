# Phoenix DIP 生产环境配置模板。
# 复制到服务器 /opt/phoenix-dip/.env 后填写,切勿提交真实值到仓库。

# --- 访问入口(Traefik)---
DIP_DOMAIN=dip.matrix-net.tech
TRAEFIK_ENTRYPOINT=websecure
TRAEFIK_CERTRESOLVER=aliyunresolver

# --- 镜像来源(与 .github/workflows/deploy.yml 一致)---
REGISTRY=registry.cn-hangzhou.aliyuncs.com
REGISTRY_NAMESPACE=yuanyuexiang
# TAG 通常由部署命令注入(TAG=sha-xxxxxxx docker compose ...),不在此固定

# --- 机密(必填)---
POSTGRES_PASSWORD=change-me
MINIO_ROOT_PASSWORD=change-me
PHX_ADMIN_PASSWORD=change-me     # 管理后台访问密码,同时是 mcp→workflow 的内部凭证

# --- 可选覆盖 ---
POSTGRES_USER=phoenix
POSTGRES_DB=phoenix
MINIO_ROOT_USER=phoenix

# --- 大模型(留空用 Mock 提取器;说明书 §13 模型来源可配置)---
PHX_LLM_ENDPOINT=
PHX_LLM_API_KEY=
PHX_LLM_MODEL=deepseek-chat
